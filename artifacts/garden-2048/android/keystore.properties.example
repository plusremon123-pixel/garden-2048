# -----------------------------------------------------------
# Release 서명용 keystore 정보
# -----------------------------------------------------------
# 이 파일을 복사해서 keystore.properties 로 저장하고 실제 값 채우기
#   cp keystore.properties.example keystore.properties
#
# ⚠️  keystore.properties 와 *.keystore / *.jks 파일은 절대 git 커밋 금지!
#     (.gitignore 에 이미 등록되어 있음)
#
# 🔑  keystore 생성 명령 (최초 1회, Android Studio 없이 CLI로도 가능):
#   keytool -genkey -v \
#     -keystore garden2048-release.keystore \
#     -alias garden2048 \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# 💾  생성된 keystore 파일은 별도로 백업! (암호·파일 유실 시 Play Store 업로드 영구 불가)
# -----------------------------------------------------------

# keystore 파일의 android/ 기준 상대경로 (예: 같은 폴더에 두면 파일명만)
storeFile=garden2048-release.keystore

# keystore 접근 암호
storePassword=your_keystore_password_here

# key alias (keystore 안에 있는 키 별칭)
keyAlias=garden2048

# key 암호 (보통 storePassword와 동일하게 설정)
keyPassword=your_key_password_here
